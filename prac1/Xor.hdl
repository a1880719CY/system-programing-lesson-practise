// File name: projects/01/Xor.hdl

/**
 * Exclusive-or gate:
 * out = not (a == b)
 */

CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Not(in=a, out=naout);
    Not(in=b, out=nbout);
    Nand(a=a, b=nbout, out=aout);
    Nand(a=b, b=naout, out=bout);
    Nand(a=aout, b=bout, out=out);
}